generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        String   @id @default(uuid())
  title     String   @unique
  content   String
  slug      String   @unique
  tags      Tag[]
  createdAt DateTime @default(now())
}
model Tag {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[]
}

model Contact {
  id        String   @id @default(uuid())
  name     String
  message   String
  email   String @unique
  createdAt DateTime @default(now())
}
